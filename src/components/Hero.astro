---
// Hero Section
---

<section class="hero" id="home">
  <!-- Grid overlay for architectural feel -->
  <div class="hero-grid-overlay" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-content">
      <p class="section-label">Infrastructure That Can't Fail</p>
      <h1 class="hero-headline">
        We Build <span class="accent-text">Audit-Ready</span><br />
        Infrastructure for<br />
        Organizations That Can't<br />
        Afford to Fail.
      </h1>
      <p class="hero-sub">
        We bridge the critical gap between enterprise-grade security and operational agility.
        By integrating rigorous identity management, automated compliance documentation,
        and disaster-resilient architecture, we ensure your technology stack supports
        your business objectives—from daily operations to regulatory audits.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn btn-primary">Schedule a Consultation</a>
        <a href="#services" class="btn btn-outline">View Services</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-value">FDA</span>
          <span class="stat-label">cGMP Validated</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">NIST</span>
          <span class="stat-label">Framework Aligned</span>
        </div>
        <div class="stat-divider" aria-hidden="true"></div>
        <div class="stat">
          <span class="stat-value">FINRA</span>
          <span class="stat-label">Compliance Ready</span>
        </div>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="blueprint-card">
        <div class="bp-header">
          <span class="bp-dot bp-dot--amber"></span>
          <span class="bp-dot bp-dot--dim"></span>
          <span class="bp-dot bp-dot--dim"></span>
          <span class="bp-label">SYSTEM STATUS</span>
        </div>
        <ul class="bp-items">
          <li><span class="bp-check">✔</span> Identity Management<span class="bp-status bp-status--ok">HARDENED</span></li>
          <li><span class="bp-check">✔</span> DR Architecture<span class="bp-status bp-status--ok">VALIDATED</span></li>
          <li><span class="bp-check">✔</span> Compliance Binder<span class="bp-status bp-status--ok">CURRENT</span></li>
          <li><span class="bp-check">✔</span> Audit Readiness<span class="bp-status bp-status--ok">READY</span></li>
          <li><span class="bp-check">✔</span> Endpoint Mgmt<span class="bp-status bp-status--ok">ENROLLED</span></li>
        </ul>
        <div class="bp-footer">
          <span class="bp-pulse" aria-hidden="true"></span>
          All systems audit-ready
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 68px; /* nav height */
    overflow: hidden;
    background: var(--color-bg-base);
  }

  /* Subtle architectural grid overlay */
  .hero-grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(212, 160, 23, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(212, 160, 23, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 40%, transparent 100%);
    pointer-events: none;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-4xl);
    align-items: center;
    padding-block: var(--space-4xl);
  }

  .hero-content { position: relative; z-index: 1; }

  .hero-headline {
    margin-bottom: var(--space-lg);
    line-height: 1.1;
  }

  .accent-text {
    color: var(--color-accent);
    font-style: italic;
  }

  .hero-sub {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    max-width: 56ch;
    margin-bottom: var(--space-2xl);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  /* Stats bar */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-value {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-accent);
    letter-spacing: 0.05em;
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 2rem;
    background: var(--color-border-subtle);
  }

  /* Blueprint card */
  .hero-visual {
    position: relative;
    z-index: 1;
  }

  .blueprint-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    box-shadow: var(--shadow-card), var(--shadow-accent);
    position: relative;
    overflow: hidden;
  }

  .blueprint-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light), var(--color-accent));
  }

  .bp-header {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-lg);
  }

  .bp-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    display: inline-block;
  }

  .bp-dot--amber { background: var(--color-accent); }
  .bp-dot--dim   { background: var(--color-bg-elevated); }

  .bp-label {
    margin-left: auto;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
    text-transform: uppercase;
  }

  .bp-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .bp-items li {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .bp-check {
    color: var(--color-accent);
    font-size: 0.75rem;
    flex-shrink: 0;
  }

  .bp-status {
    margin-left: auto;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    padding: 2px 8px;
    border-radius: 20px;
  }

  .bp-status--ok {
    color: #4ade80;
    background: rgba(74, 222, 128, 0.1);
    border: 1px solid rgba(74, 222, 128, 0.25);
  }

  .bp-footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.78rem;
    color: var(--color-text-muted);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-subtle);
  }

  .bp-pulse {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: #4ade80;
    display: inline-block;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  /* Responsive */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hero-sub { margin-inline: auto; }
    .hero-actions { justify-content: center; }
    .hero-stats { justify-content: center; }
    .hero-visual { display: none; }
  }
</style>
