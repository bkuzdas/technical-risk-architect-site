---
// Services Section
const tiers = [
  {
    tier: 'I',
    label: 'Audit & Strategy',
    mode: 'Consultative',
    icon: '◈',
    description: 'Deep-dive assessment and roadmap development. We evaluate where you stand and architect a path to compliance.',
    services: [
      {
        name: 'Regulatory Gap Analysis',
        desc: 'Comprehensive review of existing infrastructure against industry-specific standards — FDA/cGMP, FINRA, NIST frameworks, and beyond.',
      },
      {
        name: 'DR & Business Continuity Planning',
        desc: 'Architecture design for full system recovery, ensuring RPO and RTO targets are met, tested, and fully documented.',
      },
      {
        name: 'Infrastructure Readiness Audit',
        desc: 'A technical "pre-flight" for businesses approaching third-party audits. Find the gaps before the auditors do.',
      },
    ],
  },
  {
    tier: 'II',
    label: 'Infrastructure Hardening',
    mode: 'Project-Based',
    icon: '⬡',
    description: 'Tactical implementation of secure, high-performance systems. We build the architecture — and document every step.',
    services: [
      {
        name: 'Identity & Access Modernization',
        desc: 'Implementation of enterprise-grade identity providers (Authentik, Entra ID) with MFA and hardware token integration (YubiKey).',
      },
      {
        name: 'Unified Endpoint Management',
        desc: 'Secure deployment and policy enforcement using Microsoft Intune and Entra ID across every managed device.',
      },
      {
        name: 'Secure AI Cluster Design',
        desc: 'Architecture and setup of on-premises HPC clusters for localized, secure, air-gapped AI data processing.',
      },
    ],
  },
  {
    tier: 'III',
    label: 'Managed Risk Architecture',
    mode: 'Retainer',
    icon: '⬟',
    description: 'Long-term peace of mind. Proactive oversight so your systems are compliant 365 days a year — not just on audit day.',
    services: [
      {
        name: 'Virtual CISO / Infrastructure Architect',
        desc: 'Ongoing strategic oversight of security hardening, policy governance, and technical infrastructure direction.',
      },
      {
        name: 'Continuous Compliance Monitoring',
        desc: 'Proactive maintenance ensuring systems remain in a compliant state year-round — no scrambling when auditors arrive.',
      },
      {
        name: 'Disaster Recovery Lifecycle Management',
        desc: 'Periodic testing and verification of backup integrity, restoration procedures, and recovery documentation.',
      },
    ],
  },
];
---

<section class="section section--alt" id="services">
  <div class="container">
    <div class="accent-line"></div>
    <p class="section-label">What We Do</p>
    <h2 class="section-heading">A Tiered Approach to<br /><span class="accent-text">Risk Architecture</span></h2>
    <p class="section-intro">
      Every engagement is structured around business impact — from strategic assessment to daily managed oversight.
      Choose the level of partnership your organization needs.
    </p>

    <div class="tiers-grid">
      {tiers.map((tier) => (
        <div class="tier-card">
          <div class="tier-header">
            <div class="tier-badge">
              <span class="tier-icon" aria-hidden="true">{tier.icon}</span>
              <span class="tier-num">Tier {tier.tier}</span>
            </div>
            <span class="tier-mode">{tier.mode}</span>
          </div>
          <h3 class="tier-title">{tier.label}</h3>
          <p class="tier-desc">{tier.description}</p>
          <ul class="service-list">
            {tier.services.map((svc) => (
              <li class="service-item">
                <span class="service-arrow" aria-hidden="true">→</span>
                <div>
                  <strong class="service-name">{svc.name}</strong>
                  <p class="service-desc">{svc.desc}</p>
                </div>
              </li>
            ))}
          </ul>
          <a href="#contact" class="tier-cta">Inquire About This Tier →</a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .accent-text { color: var(--color-accent); }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: start;
  }

  .tier-card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    transition: border-color var(--transition-base), box-shadow var(--transition-base), transform var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .tier-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .tier-card:hover {
    border-color: var(--color-border);
    box-shadow: var(--shadow-card), var(--shadow-accent);
    transform: translateY(-4px);
  }

  .tier-card:hover::before { opacity: 1; }

  .tier-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-sm);
  }

  .tier-badge {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .tier-icon {
    font-size: 1.25rem;
    color: var(--color-accent);
  }

  .tier-num {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .tier-mode {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    padding: 3px 10px;
    border: 1px solid var(--color-border-subtle);
    border-radius: 20px;
  }

  .tier-title {
    font-size: 1.25rem;
    color: var(--color-text-primary);
    line-height: 1.3;
  }

  .tier-desc {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    max-width: none;
    border-bottom: 1px solid var(--color-border-subtle);
    padding-bottom: var(--space-md);
  }

  .service-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    flex: 1;
  }

  .service-item {
    display: flex;
    gap: var(--space-sm);
    align-items: flex-start;
  }

  .service-arrow {
    color: var(--color-accent);
    font-size: 0.85rem;
    margin-top: 3px;
    flex-shrink: 0;
    line-height: 1;
  }

  .service-name {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 4px;
  }

  .service-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: none;
  }

  .tier-cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.01em;
    margin-top: var(--space-sm);
    transition: gap var(--transition-base), color var(--transition-base);
    gap: var(--space-xs);
  }

  .tier-cta:hover { color: var(--color-accent-light); gap: var(--space-sm); }

  @media (max-width: 960px) {
    .tiers-grid { grid-template-columns: 1fr; max-width: 560px; margin-inline: auto; }
  }
</style>
